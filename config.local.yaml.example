# LiteLLM model config
# All requests route through the proxy sidecar to opencode serve on the host.
#
# Usage:
#   1. Start opencode:   opencode serve --port 4096
#   2. Start the stack:  make up

model_list:
  # ── Anthropic ────────────────────────────────────────────────────────────────
  - model_name: claude-3-haiku-20240307
    litellm_params:
      model: anthropic/claude-3-haiku-20240307
      api_base: http://proxy:8080
      api_key: not-used

  - model_name: claude-opus-4-0
